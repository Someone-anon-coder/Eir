{
  "name": "playwright-eir",
  "version": "0.2.0",
  "description": "Self-healing locator engine for Playwright. Under active development.",
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "self-healing",
    "locators"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Someone-anon-coder/Eir.git",
    "directory": "packages/eir"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./globalTeardown": {
      "types": "./dist/store/globalTeardown.d.ts",
      "import": "./dist/store/globalTeardown.js",
      "default": "./dist/store/globalTeardown.js"
    },
    "./reporter": {
      "types": "./dist/reporter/eirReporter.d.ts",
      "import": "./dist/reporter/eirReporter.js",
      "default": "./dist/reporter/eirReporter.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
