# Aayush's TS-tip playground — scratch only, never shipped
ts-scratch/

# Eir fingerprint/post-condition store: per-worker scratch shards, merged
# away in globalTeardown and never meant to be committed. `.eir/routes/`
# is NOT ignored — that's the committed baseline (Blueprint §7.3), and
# that includes its post-condition sibling files (NOTE-001, Phase 6).
.eir/.shards/
.eir/.shards-postconditions/

# Eir's custom reporter output (Phase 6): regenerated every run, like
# playwright-report/ above — never a committed artifact.
eir-report/

# The benchmark's probe runs also go through playwright-eir (for realism —
# see probes/probe.spec.ts), but they're synthetic per-run captures, not a
# calibrated baseline worth preserving — unlike demo-app's `.eir/routes/`.
packages/benchmark/.eir/
